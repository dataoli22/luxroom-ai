# LuxRoom AI — Environment Configuration Example
# In the desktop app, all settings are configured through the onboarding wizard and stored
# in your OS user-data folder. This file is only needed if you are running the pipeline
# directly from the command line (npm start / node src/pipeline.js).
#
# Copy this file to .env and fill in your values.

# ── AI inference ──────────────────────────────────────────────────────────────

# Local inference (default — nothing leaves your device)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Cloud fallback (optional — only listing HTML is sent, never your personal data)
# CLOUD_API_URL=https://api.groq.com/openai/v1
# CLOUD_API_KEY=gsk_...
# CLOUD_MODEL=llama-3.1-8b-instant

# ── Email notifications ───────────────────────────────────────────────────────

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
# Use a Gmail App Password, not your regular password:
# https://myaccount.google.com/apppasswords
SMTP_PASS=your_app_password_here
SMTP_FROM=LuxRoom AI <you@gmail.com>
NOTIFICATION_EMAIL=you@gmail.com

# ── Pipeline ──────────────────────────────────────────────────────────────────

DB_PATH=./data/luxroom.db
CRAWL_INTERVAL_HOURS=3
OPPORTUNITY_THRESHOLD=8

# ── Approval mode ─────────────────────────────────────────────────────────────

# manual = you approve every message (default)
# auto   = messages scoring >= AUTO_APPROVE_THRESHOLD are sent automatically
APPROVAL_MODE=manual
AUTO_APPROVE_THRESHOLD=9
