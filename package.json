{
  "name": "luxroom-ai",
  "version": "1.7.1",
  "description": "Open-source automated housing agent for Luxembourg — find your room before September.",
  "main": "electron/main.bundle.js",
  "scripts": {
    "build:main": "esbuild electron/main.js --bundle --platform=node --target=node20 --external:electron --external:nodemailer --external:electron-updater --outfile=electron/main.bundle.js",
    "dev": "npm run build:main && concurrently \"vite\" \"wait-on http://localhost:5173 && node launch-electron.cjs\"",
    "build": "npm run build:main && vite build && electron-builder --win",
    "build:mac": "npm run build:main && vite build && electron-builder --mac",
    "build:linux": "npm run build:main && vite build && electron-builder --linux",
    "vite": "vite",
    "electron": "electron .",
    "start": "node src/pipeline.js",
    "crawl": "node src/modules/discovery/crawler.js",
    "smoke": "node smoke-test.mjs",
    "approve": "node src/modules/hermes/approve.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "cron": "^3.1.7",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.8.9",
    "node-fetch": "^3.3.2",
    "node-notifier": "^10.0.1",
    "nodemailer": "^6.9.13",
    "playwright": "^1.44.0",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.28.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  }
}
